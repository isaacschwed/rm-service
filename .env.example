# Copy this to .env and fill in values for local development.
# NEVER commit .env to git.

# PostgreSQL (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/rm_service

# Redis
REDIS_URL=redis://localhost:6379/0

# Fernet master key for HKDF per-company key derivation
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_MASTER_KEY=

# Rent Manager base URL — confirm on first real RM auth call
RM_BASE_URL=https://api.rentmanager.com

# Admin API key — separate from platform API keys
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=

# Sentry DSN (optional in dev)
SENTRY_DSN=

# App
APP_ENV=development
APP_VERSION=1.0.0
LOG_LEVEL=INFO
